{
  "expo": {
    "name": "Right Wash",
    "slug": "right-wash",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rightwash",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rightwash.mobile"
    },
    "android": {
      "package": "com.rightwash.mobile",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050812"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
